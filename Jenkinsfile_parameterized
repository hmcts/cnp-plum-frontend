#!groovy
@Library(value="Infrastructure", changelog=false)

List<LinkedHashMap<String, Object>> apiTestSecrets = [
  secret('test-client-key-store', 'TEST_CLIENT_KEY_STORE'),
  secret('test-client-key-store-password', 'TEST_CLIENT_KEY_STORE_PASSWORD'),
  secret('test-client-subscription-key', 'TEST_CLIENT_SUBSCRIPTION_KEY')
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

properties([
  parameters([
    string(name: 'PRODUCT_NAME', defaultValue: 'plum', description: ''),
    string(name: 'APP', defaultValue: 'frontend', description: ''),
    string(name: 'TYPE', defaultValue: 'nodejs', description: ''),
    string(name: 'ENVIRONMENT', defaultValue: 'sandbox', description: 'Environment where code should be build and deployed'),
    choice(name: 'SUBSCRIPTION', choices: 'sandbox\nnonprod\nprod\nhmctsdemo', description: 'Azure subscriptions available to build in')
  ]),
  [$class: 'GithubProjectProperty', projectUrlStr: 'github.com/contino/cnp-plum-frontend '],
  pipelineTriggers([[$class: 'GitHubPushTrigger']])
])

def expiresAfter = "3000-01-01"
def appPipelineConfig = new uk.gov.hmcts.contino.AppPipelineConfig()
def callbacks = new uk.gov.hmcts.contino.PipelineCallbacksConfig()
def callbacksRunner = new uk.gov.hmcts.contino.PipelineCallbacksRunner(callbacks)
def aksSubscriptions = new uk.gov.hmcts.pipeline.AKSSubscriptions(this)
def latestDockerImage
def acr


withParameterizedPipeline(params.TYPE, params.PRODUCT_NAME, params.APP, params.ENVIRONMENT, params.SUBSCRIPTION) {
  //enableApiGatewayTest()
  disableLegacyDeployment()
  afterSuccess('build') {
    withAcrClient(params.SUBSCRIPTION) {
      def imageRegistry = env.TEAM_CONTAINER_REGISTRY ?: env.REGISTRY_NAME
      acr = new uk.gov.hmcts.contino.azure.Acr(this, params.SUBSCRIPTION, imageRegistry, env.REGISTRY_RESOURCE_GROUP, env.REGISTRY_SUBSCRIPTION)
      latestDockerImage = new uk.gov.hmcts.contino.DockerImage(params.PRODUCT_NAME, params.APP, acr, 'latest', env.GIT_COMMIT, env.LAST_COMMIT_TIMESTAMP)
      acr.build(latestDockerImage)
    }
  }
  afterSuccess("buildinfra:${params.ENVIRONMENT}") {
    if (params.ENVIRONMENT == 'sandbox') {
      lock(resource: "${params.PRODUCT_NAME}-${params.APP}-${params.ENVIRONMENT}-deploy", inversePrecedence: true) {
        withAksClient(params.SUBSCRIPTION, params.ENVIRONMENT, params.PRODUCT_NAME) {
          helmInstall(latestDockerImage, [
            subscription: params.SUBSCRIPTION,
            environment: params.ENVIRONMENT,
            product: params.PRODUCT_NAME,
            component: params.APP,
            aksSubscription: aksSubscriptions.sandbox,
            appPipelineConfig: appPipelineConfig
          ])
        }
      }
    }
  }
  onNonPR() {
    //loadVaultSecrets(apiTestSecrets)
  }
  expires(expiresAfter)
}
