#!groovy

@Library("Infrastructure@DTSPO-30107-jenkins-agents")

def type = "nodejs"
def product = "plum"
def component = "frontend" 
def expiresAfter = "3000-01-01"

def secrets = [ 'plumsi-${env}':
  [
    secret('AppInsightsInstrumentationKey', 'APPINSIGHTS_INSTRUMENTATIONKEY')
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

withPipeline(type, product, component) {
  loadVaultSecrets(secrets)
  disableLegacyDeployment()
  expires(expiresAfter)

  afterAlways('build') {
    yarnBuilder.yarn('rebuild puppeteer')
    yarnBuilder.yarn('build')
  }

  before('functionalTest:preview') {
    sh """
      if [ -z "$TEST_URL" ] && [ -n "$SERVICE_FQDN" ]; then
        export TEST_URL="https://$SERVICE_FQDN"
      fi
      echo "Using TEST_URL=${TEST_URL:-http://localhost:1337}"
      yarn install
      yarn playwright install
    """
  }

  before('functionalTest:aat') {
    sh """
      if [ -z "$TEST_URL" ] && [ -n "$SERVICE_FQDN" ]; then
        export TEST_URL="https://$SERVICE_FQDN"
      fi
      echo "Using TEST_URL=${TEST_URL:-http://localhost:1337}"
      yarn install
      yarn playwright install
    """
  }

  before('functionalTest:perftest') {
    sh """
      if [ -z "$TEST_URL" ] && [ -n "$SERVICE_FQDN" ]; then
        export TEST_URL="https://$SERVICE_FQDN"
      fi
      echo "Using TEST_URL=${TEST_URL:-http://localhost:1337}"
      yarn install
      yarn playwright install
    """
  }

}
